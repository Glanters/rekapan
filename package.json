{
  "name": "monthly",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 7564",
    "build": "next build",
    "start": "next start -p 7564",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "php:vectors": "php tools/php-parity/generate-vectors.php",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "prisma migrate reset",
    "db:studio": "prisma studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:install": "docker compose --profile tools run --rm prisma npm install",
    "docker:migrate": "docker compose --profile tools run --rm prisma npx prisma migrate dev",
    "docker:deploy": "docker compose --profile tools run --rm prisma npx prisma migrate deploy",
    "docker:seed": "docker compose --profile tools run --rm prisma npm run db:seed",
    "docker:reset": "docker compose --profile tools run --rm prisma npx prisma migrate reset --force",
    "docker:sh": "docker compose --profile tools run --rm prisma bash",
    "prepare": "husky",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1091.0",
    "@aws-sdk/s3-request-presigner": "^3.1091.0",
    "@base-ui/react": "^1.6.0",
    "@hookform/resolvers": "^5.4.0",
    "@prisma/adapter-pg": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "@tanstack/react-query": "^5.101.3",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.7",
    "archiver": "^7.0.1",
    "bullmq": "^5.80.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.4.0",
    "exceljs": "^4.4.0",
    "html-to-image": "^1.11.13",
    "ioredis": "^5.11.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.25.0",
    "next": "15.5.20",
    "next-themes": "^0.4.6",
    "pg": "^8.22.0",
    "prisma": "^7.9.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-hook-form": "^7.82.0",
    "recharts": "^3.10.0",
    "shadcn": "^4.13.1",
    "sharp": "^0.35.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/archiver": "^7.0.0",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.3",
    "dotenv": "^17.4.2",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.5.20",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.6",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "tailwindcss": "^4",
    "tsx": "^4.23.1",
    "typescript": "^5",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md,css,yml,yaml}": [
      "prettier --write"
    ]
  }
}
