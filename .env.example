# =============================================================================
# Enterprise Monthly & Turnover Management System
# -----------------------------------------------------------------------------
# Copy to .env and fill in. Every variable is validated at boot by
# src/lib/env.ts, which reports all problems at once instead of failing on the
# first one it happens to touch.
# =============================================================================

NODE_ENV=development
APP_URL=http://localhost:3000

# -- Database -----------------------------------------------------------------
# Matches docker-compose.yml. Port 5433 on the host, not 5432 — a natively
# installed PostgreSQL frequently occupies 5432, and the resulting failure is
# confusing because both instances bind successfully (one IPv4, one IPv6) and
# `localhost` silently picks the wrong one.
DATABASE_URL="postgresql://monthly:monthly_dev_password@localhost:5433/monthly?schema=public"

# -- Account Center (identity provider) ---------------------------------------
# Names map onto the Laravel config keys these values already live under:
#   services.accountcenter.uri    -> ACCOUNT_CENTER_URL
#   services.accountcenter.name   -> ACCOUNT_CENTER_CLIENT_ID  (sent as X-Client-Id)
#   services.accountcenter.secret -> ACCOUNT_CENTER_SECRET     (md5'd into the AES key)
#
# ACCOUNT_CENTER_SECRET must be byte-identical to the Laravel value. It is
# hashed to derive the AES key, so a single differing character produces a
# signature the server rejects with no useful diagnostic.
ACCOUNT_CENTER_URL=https://account-center.example.com
ACCOUNT_CENTER_CLIENT_ID=monthly-turnover-app
ACCOUNT_CENTER_SECRET=replace-me
ACCOUNT_CENTER_TIMEOUT_MS=15000

# -- Bootstrap ----------------------------------------------------------------
# The one Account Center account seeded as Root and activated automatically.
# Everyone else lands in PENDING and needs an administrator to approve them.
ROOT_EMAIL=root@example.com

# NOTE ON ROOT_PASSWORD
# Your original specification listed ROOT_PASSWORD, but it is deliberately absent
# here. Account Center owns credential verification; storing a root password in
# this app would create a second authentication path that bypasses it — weaker
# than the one it sits beside, and outside your audit trail. If you want a
# break-glass local login for when Account Center is unreachable, say so and it
# can be added explicitly, rate-limited and audited as its own feature.

# -- Secrets ------------------------------------------------------------------
# Generate fresh values per environment:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=replace-me-with-48-random-bytes
ENCRYPTION_KEY=replace-me-with-64-hex-characters
SESSION_TTL_HOURS=12

# -- Redis (BullMQ background jobs) -------------------------------------------
REDIS_URL=redis://localhost:6379

# -- Object storage -----------------------------------------------------------
# S3-compatible. Local dev points at MinIO; production points at Cloudflare R2,
# AWS S3, or any compatible provider. Only these values change.
#
# MinIO requires path-style addressing. R2 and S3 use virtual-hosted style, so
# set S3_FORCE_PATH_STYLE=false there or every asset URL 404s.
S3_ENDPOINT=http://localhost:9000
S3_REGION=auto
S3_BUCKET=monthly-assets
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/monthly-assets
S3_FORCE_PATH_STYLE=true

# -- Limits -------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=25
# Gallery selections above this count are queued as a background job rather than
# streamed inline, so a request never holds a connection open for minutes.
ZIP_SYNC_THRESHOLD=50
